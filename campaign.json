        "Messenberg Explosion Investigation": [
            {
                "writer": "amanuel@press.pt",
                "writerName": "Alease Manuel",
                "title": "Explosion in Messenberg",
                "content": [
                    {
                        "text": "Employee involved in independence parade caught on CCTV footage sabotaging the vehicle that exploded by attempting to cut the wire using a small knife, but failed",
                        "isContent": true,
                        "webpage": false,
                        "effect": {
                            "false": [2, -1, 1, -1],
                            "true": [-3, 2, -1, 3]
                        }
                    },
                    {
                        "text": "After interrogation, the worker revealed 3 more workers being involved in the situation, but refused to reveal their names.",
                        "isContent": true,
                        "webpage": false,
                        "effect": {
                            "false": [1, -1, 0, -1],
                            "true": [-2, 1, 0, 2]
                        }
                    },
                    {
                        "text": "Motive of their crime is unknown, but some speculated it to be a crime of passion",
                        "isContent": true,
                        "webpage": false,
                        "effect": {
                            "false": [0, -1, 0, 0],
                            "true": [-1, 1, 0, 1]
                        }
                    },
                    {
                        "text": "9 have been selected as suspect in the investigation",
                        "isContent": true,
                        "webpage": false,
                        "effect": {
                            "false": [1, -1, 0, -1],
                            "true": [-1, 1, 0, 1]
                        }
                    },
                    {
                        "text": "Further investigation is underway",
                        "isContent": true,
                        "webpage": false,
                        "effect": {
                            "false": [-1, -1, 0, 0],
                            "true": [1, 0, 1, -1]
                        }
                    },
                    {
                        "text": "Company associated said that the lack of coordination and security caused the incident to happen, and that it won’t happen in the future",
                        "isContent": true,
                        "webpage": false,
                        "effect": {
